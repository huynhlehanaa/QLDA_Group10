# Database
DATABASE_URL=postgresql://admin:secret123@localhost:5432/kpi_system

# JWT - đổi thành chuỗi random dài ít nhất 32 ký tự trước khi deploy
SECRET_KEY=change-this-to-a-very-long-random-secret-key-min-32-chars

# Redis
REDIS_URL=redis://localhost:6379

# Email SMTP (bỏ trống để dùng console log trong dev)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@kpinoibo.com
MAIL_FROM_NAME=KPI Nội Bộ
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# AES-256 key (đúng 32 ký tự)
AES_KEY=12345678901234567890123456789012

# App URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:8000
